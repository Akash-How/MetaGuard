{
  "mcpServers": {
    "metaguard": {
      "command": "python",
      "args": ["-m", "app.mcp.server"],
      "env": {}
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "YOUR_SLACK_BOT_TOKEN_HERE",
        "SLACK_APP_TOKEN": "YOUR_SLACK_APP_TOKEN_HERE",
        "SLACK_TEAM_ID": "YOUR_SLACK_TEAM_ID_HERE"
      }
    }
  }
}
